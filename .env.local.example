# Zmeurel OS — Environment Variables
# Variabile obligatorii: NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY
# Variabile opționale: GOOGLE_CLIENT_*, SENTRY_*, AI_*
#
# Playwright E2E — cont superadmin manual (doar dacă DB-ul blochează update `is_superadmin` via service role):
# E2E_SUPERADMIN_EMAIL=
# E2E_SUPERADMIN_PASSWORD=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Web Push (VAPID) — `npx web-push generate-vapid-keys` (public în client, privat doar server)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_SUBJECT=mailto:admin@example.com
SITE_URL=
NEXT_PUBLIC_SITE_URL=
SUPABASE_SERVICE_ROLE_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
# Cheie server-only pentru criptarea tokenurilor Google Contacts la rest (32 bytes base64)
# Exemplu generare: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
GOOGLE_TOKENS_ENCRYPTION_KEY=
# Cheie server-only pentru step-up auth pe acțiuni destructive (minim 32 bytes; recomandat random base64)
# Exemplu generare: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
DESTRUCTIVE_ACTION_STEP_UP_SECRET=
CRON_SECRET=
APP_BASE_URL=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_PERF_LOG=false

# AI Chat (Gemini)
GOOGLE_GENERATIVE_AI_API_KEY=
AI_GEMINI_MODEL=gemini-2.5-flash
AI_GEMINI_SIMPLE_MODEL=gemini-2.0-flash-lite
AI_CHAT_DAILY_LIMIT=20
AI_CHAT_PRIVILEGED_DAILY_LIMIT=60

# AI Chat (opțional)
AI_CHAT_MAX_OUTPUT_TOKENS=220
AI_CHAT_USAGE_LOG=false
AI_CHAT_PRIVILEGED_USER_IDS=uuid_1,uuid_2

# Shop / email notifications
SHOP_ORDER_NOTIFY_FROM=
SHOP_ORDER_NOTIFY_EMAIL=
SHOP_ORDER_NOTIFY_RESEND_API_KEY=
RESEND_API_KEY=

# Association fallback allowlists (legacy / tranziție)
ASSOCIATION_ALLOWED_OWNER_USER_IDS=uuid_1,uuid_2
ASSOCIATION_ALLOWED_EMAILS=owner@example.com

# Superadmin protection allowlists (CSV user IDs)
ACCOUNT_DELETE_PROTECTED_USER_IDS=uuid_1,uuid_2
DEMO_CLEANUP_PROTECTED_OWNER_USER_IDS=uuid_1,uuid_2
CLEANUP_DEMOS_PROTECTED_USER_IDS=uuid_1,uuid_2
CLEANUP_BETA_PROTECTED_USER_IDS=uuid_1,uuid_2
RESET_TEST_USERS_PROTECTED_USER_IDS=uuid_1,uuid_2

# Sentry (opțional)
SENTRY_AUTH_TOKEN=
# Override explicit release (altfel: VERCEL_GIT_COMMIT_SHA sau NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA)
SENTRY_RELEASE=
# Link direct către proiect Sentry (Issues etc.) — folosit în admin /admin/analytics → Tech Health
NEXT_PUBLIC_SENTRY_DASHBOARD_URL=
# Opțional: același commit ca pe server pentru release în bundle-ul client (Vercel poate seta automat pe unele planuri)
NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA=

# Supabase Edge Functions (setează în Supabase Secrets, nu în bundle-ul client)
OPENWEATHER_API_KEY=
OPENWEATHERMAP_API_KEY=
