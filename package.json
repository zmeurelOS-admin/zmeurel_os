{
  "name": "zmeurel",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "lint": "eslint",
    "lint:ai-chat": "eslint src/app/api/chat/route.ts src/app/api/chat/contract-helpers.ts src/lib/financial/chat-router.ts",
    "typecheck": "tsc --noEmit",
    "check:backup-readiness": "node scripts/check-backup-readiness.mjs",
    "check:staging-readiness": "node scripts/check-staging-readiness.mjs",
    "check:sensitive-hardcoding": "node scripts/check-sensitive-hardcoding.mjs",
    "test:ai-chat": "playwright test --config=playwright.ai-chat.config.ts",
    "test:ai-chat:integration": "playwright test --config=playwright.ai-chat.integration.config.ts",
    "check:ai-chat": "npm run lint:ai-chat && npm run typecheck && npm run test:ai-chat",
    "check:ai-chat:ci": "npm run check:ai-chat && npm run test:critical:integration",
    "test:critical:unit": "vitest run --config vitest.critical.config.ts",
    "test:critical": "npm run test:critical:unit",
    "test:critical:integration": "npm run test:ai-chat:integration",
    "test:critical:full": "npm run test:critical && npm run test:critical:integration",
    "check:critical": "npm run check:sensitive-hardcoding && npm run lint && npm run typecheck && npm run test:critical",
    "predeploy:ai-chat": "npm run check:ai-chat",
    "test:e2e": "playwright test",
    "test:e2e:checkout": "playwright test --config playwright.config.checkout.ts",
    "test:e2e:checkout:ui": "playwright test --config playwright.config.checkout.ts --ui",
    "prebuild": "node scripts/check-env.js",
    "build": "next build --webpack",
    "postbuild": "node scripts/append-push-sw-import.js",
    "check": "npm run check:critical && npm run build",
    "test": "vitest",
    "test:rls": "vitest run --config vitest.rls.config.ts",
    "test:rls:watch": "vitest --config vitest.rls.config.ts",
    "test:run": "vitest run",
    "start": "next start"
  },
  "dependencies": {
    "@ai-sdk/google": "^1.2.22",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@sentry/nextjs": "^10.40.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.95.3",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-table": "^8.21.3",
    "@types/react-grid-layout": "^1.3.6",
    "ai": "^4.3.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "driver.js": "^1.4.0",
    "framer-motion": "^12.35.2",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.563.0",
    "next": "16.2.3",
    "next-pwa": "^5.6.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-grid-layout": "^2.2.3",
    "react-hook-form": "^7.71.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "web-push": "^3.6.7",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.33",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^29.0.1",
    "shadcn": "^3.8.4",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
